{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fileogenetic Tree",
  "version": "0.1.0",
  "identifier": "com.fileogenetic.tree",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fileogenetic Tree",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 540
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "A living, indexed map of your filesystem"
  }
}

